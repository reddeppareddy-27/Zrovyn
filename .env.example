# Django Settings
# Set DEBUG=False in production (Render)
DEBUG=False
SECRET_KEY=your-secret-key-here-use-django-secret-key-generator

# For production on Render, Render will provide your domain, e.g., finance-dashboard-xyz.onrender.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For LOCAL DEVELOPMENT (SQLite):
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# For LOCAL DEVELOPMENT (PostgreSQL):
DB_ENGINE=django.db.backends.postgresql
DB_NAME=Backend_Intern
DB_USER=Backend_Intern
DB_PASSWORD=Reddy@2005
DB_HOST=localhost
DB_PORT=5432

# For RENDER PRODUCTION:
# Render will automatically set DATABASE_URL environment variable
# Django will parse it automatically if you use the config in settings.py
